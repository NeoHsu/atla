{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NeoHsu/atla/docs/schemas/schema-list-v1.schema.json",
  "title": "atla schema list v1",
  "allOf": [
    { "$ref": "list-v1.schema.json" }
  ],
  "type": "object",
  "required": ["schemaVersion", "schemas", "pagination"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "schemas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "file", "description"],
        "properties": {
          "name": { "type": "string" },
          "file": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
